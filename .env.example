# Copy to .env for local docker-compose.
# DO NOT commit .env. Real deployments must NOT use these values.

POSTGRES_PASSWORD=andvari

# 32 random bytes, base64-encoded. Generate fresh with:
#   openssl rand -base64 32
ANDVARI_ROOT_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

# Pocket ID encryption key (32 random bytes, base64). Pocket ID uses this
# to seal its own database. Generate fresh with:
#   openssl rand -base64 32
ANDVARI_POCKET_ID_KEY=3cR0JqxJg2nMd1Fiu1GtJtkuBZeJxvXJh1yCDOG/2so=

RUST_LOG=info,sqlx=warn

# OIDC client credentials.
#
# Pocket ID is bundled at http://pocket-id.localhost:1411 and Andvari is
# pre-configured to use it as the OIDC issuer. Leave the four lines below
# blank until you've completed Pocket ID's first-run admin bootstrap and
# created an OAuth client for Andvari (see docs/oidc/pocket-id.md).
#
# Once you've created the client, paste the values here and run
# `docker compose up -d andvari`.
ANDVARI_OIDC_CLIENT_ID=
ANDVARI_OIDC_CLIENT_SECRET=
ANDVARI_OIDC_DEFAULT_WORKSPACE=
ANDVARI_OIDC_DEFAULT_ROLE=reader
