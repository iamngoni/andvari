# Copy to .env for local docker-compose.
# DO NOT commit .env. Real deployments must NOT use these values.

POSTGRES_PASSWORD=andvari

# 32 random bytes, base64-encoded. Generate fresh with:
#   openssl rand -base64 32
ANDVARI_ROOT_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

RUST_LOG=info,sqlx=warn

# Optional human OIDC login. Pocket ID, Authentik, Keycloak, ZITADEL, Google,
# GitHub, and other standards-compliant OIDC providers can be used.
# ANDVARI_OIDC_ISSUER=https://id.example.com
# ANDVARI_OIDC_CLIENT_ID=andvari
# ANDVARI_OIDC_CLIENT_SECRET=change-me
# ANDVARI_OIDC_REDIRECT_URL=http://localhost:8080/v1/auth/oidc/callback
# ANDVARI_OIDC_DEFAULT_WORKSPACE=spirit-finder
# ANDVARI_OIDC_DEFAULT_ROLE=reader
